{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "research-agent": {
      "description": "Research Agent - 国网优质服务研究Agent",
      "mode": "primary",
      "prompt": "{file:./AGENTS.md}",
      "skills": [
        "baidu-search",
        "literature-review",
        "observation",
        "theory-building"
      ]
    }
  },
  "mcp": {
    "baidu-search-api": {
      "type": "remote",
      "url": "https://qianfan.baidubce.com/v2/ai_search/web_search",
      "headers": {
        "Authorization": "Bearer ${BAIDU_AISEARCH_TOKEN}",
        "Content-Type": "application/json"
      },
      "enabled": true,
      "timeout": 15000,
      "method": "POST"
    }
  }
}
