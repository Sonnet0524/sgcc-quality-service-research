{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "research-agent": {
      "description": "Research Agent - 国网优质服务研究Agent",
      "mode": "primary",
      "prompt": "{file:./AGENTS.md}",
      "skills": [
        "baidu-search",
        "literature-review",
        "observation",
        "theory-building"
      ]
    }
  },
  "mcp": {
    "aisearch-mcp-server": {
      "type": "remote",
      "url": "https://qianfan.baidubce.com/v2/ai_search/mcp",
      "headers": {
        "Authorization": "Bearer ${BAIDU_AISEARCH_TOKEN}"
      },
      "enabled": true,
      "timeout": 15000
    }
  }
}
